<Window x:Class="CalculatorApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Калькулятор six seven" 
        Height="550" 
        Width="380"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        KeyDown="Window_KeyDown">

    <Grid Margin="10">
        <!-- Определяем строки Grid -->
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Заголовок -->
        <TextBlock Grid.Row="0" 
                   Text="Калькулятор" 
                   FontSize="24" 
                   FontWeight="Bold"
                   HorizontalAlignment="Center"
                   Margin="0,0,0,10"/>

        <!-- Первое число -->
        <StackPanel Grid.Row="1" Margin="0,0,0,10">
            <TextBlock Text="Первое число:" FontSize="14" 
                       Margin="0,0,0,5"/>
            <TextBox x:Name="FirstNumberTextBox" 
                     FontSize="16" 
                     Padding="5"
                     Height="35"
                     KeyDown="TextBox_KeyDown"/>
        </StackPanel>

        <!-- Второе число -->
        <StackPanel Grid.Row="2" Margin="0,0,0,10">
            <TextBlock Text="Второе число:" FontSize="14" 
                       Margin="0,0,0,5"/>
            <TextBox x:Name="SecondNumberTextBox" 
                     FontSize="16" 
                     Padding="5"
                     Height="35"
                     KeyDown="TextBox_KeyDown"/>
        </StackPanel>

        <!-- Операции -->
        <StackPanel Grid.Row="3" Margin="0,0,0,15">
            <TextBlock Text="Выберите операцию:" FontSize="14" 
                       Margin="0,0,0,10"/>

            <!-- Первая строка операций -->
            <UniformGrid Rows="1" Columns="4" Margin="0,0,0,5">
                <Button x:Name="AddButton" 
                        Content="+" 
                        FontSize="20" 
                        Margin="0,0,5,0"
                        Height="50"
                        Background="LightGreen"
                        Click="AddButton_Click"/>
                <Button x:Name="SubtractButton" 
                        Content="-" 
                        FontSize="20" 
                        Margin="0,0,5,0"
                        Height="50"
                        Background="LightBlue"
                        Click="SubtractButton_Click"/>
                <Button x:Name="MultiplyButton" 
                        Content="×" 
                        FontSize="20" 
                        Margin="0,0,5,0"
                        Height="50"
                        Background="LightSalmon"
                        Click="MultiplyButton_Click"/>
                <Button x:Name="DivideButton" 
                        Content="÷" 
                        FontSize="20" 
                        Height="50"
                        Background="LightCoral"
                        Click="DivideButton_Click"/>
            </UniformGrid>

            <!-- Вторая строка операций (дополнительные) -->
            <UniformGrid Rows="1" Columns="4">
                <Button x:Name="PowerButton" 
                        Content="x^y" 
                        FontSize="16" 
                        Margin="0,0,5,0"
                        Height="50"
                        Background="LightYellow"
                        Click="PowerButton_Click"/>
                <Button x:Name="SqrtButton" 
                        Content="√x" 
                        FontSize="16" 
                        Margin="0,0,5,0"
                        Height="50"
                        Background="LightCyan"
                        Click="SqrtButton_Click"/>
                <Button x:Name="ModButton" 
                        Content="%" 
                        FontSize="20" 
                        Margin="0,0,5,0"
                        Height="50"
                        Background="LightGray"
                        Click="ModButton_Click"/>
                <Button x:Name="ClearButton" 
                        Content="C" 
                        FontSize="20" 
                        Height="50"
                        Background="LightPink"
                        Click="ClearButton_Click"/>
            </UniformGrid>
        </StackPanel>

        <!-- Результат -->
        <StackPanel Grid.Row="4" Margin="0,0,0,10">
            <TextBlock Text="Результат:" FontSize="14" Margin="0,0,0,5"/>
            <TextBox x:Name="ResultTextBox" 
                     FontSize="18" 
                     Padding="5"
                     Height="40"
                     IsReadOnly="True"
                     Background="LightYellow"
                     FontWeight="Bold"/>
        </StackPanel>

        <!-- История операций -->
        <StackPanel Grid.Row="5" Margin="0,0,0,10">
            <TextBlock Text="История операций:" FontSize="14" Margin="0,0,0,5"/>
            <ListBox x:Name="HistoryListBox" 
                     Height="100"
                     FontSize="12"
                     Background="LightGray"/>
        </StackPanel>

        <!-- Подсказка по клавиатуре -->
        <TextBlock Grid.Row="6" 
                   Text="Используйте клавиши: +, -, *, /, P (степень), R (корень), Enter (посчитать)"
                   FontSize="10"
                   TextWrapping="Wrap"
                   Foreground="Gray"
                   Margin="0,5,0,0"/>
    </Grid>
</Window>
